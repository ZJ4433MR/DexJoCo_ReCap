# Copy this file to configs/remote.env and edit it locally.
# The copied file is ignored by git.

# SSH alias from ~/.ssh/config or an explicit host name.
REMOTE_HOST=remote-gpu

# Shared staging path visible from login and compute nodes.
REMOTE_STAGE_BASE=/tmp/$USER/dexjoco-recap-stage

# Temporary filesystem used for unpacked code, environments, and outputs.
# The runner removes each run directory after pulling results back unless
# KeepRemote is enabled.
REMOTE_BASE=/tmp/$USER/dexjoco-recap

# Existing Python environment on the remote machine.
# Keep this as shell code because clusters often need module or conda setup.
REMOTE_ENV_SETUP=source ~/miniconda3/etc/profile.d/conda.sh && conda activate dexjoco-recap

# Optional commands before the job starts, for example:
# REMOTE_BEFORE=module load cuda/12.1
REMOTE_BEFORE=

# Optional Hugging Face token setup if the remote environment does not already
# have one. Prefer HF_TOKEN_FILE for local private tokens.
HF_TOKEN=
HF_TOKEN_FILE=

# Slurm defaults. Override these for your cluster.
SLURM_PARTITION=gpu
SLURM_GRES=gpu:1
SLURM_CPUS=8
SLURM_MEM=96G
SLURM_TIME=08:00:00
