 from lerobot.utils.utils import (
     format_big_number,
     has_method,
     init_logging,
 )
 
 
+def _load_hf_dataset_for_sampling(dataset: Any) -> Any:
+    if getattr(dataset, "hf_dataset", None) is None and has_method(dataset, "_ensure_hf_dataset_loaded"):
+        dataset._ensure_hf_dataset_loaded()
+    hf_dataset = getattr(dataset, "hf_dataset", None)
+    if hf_dataset is None:
+        raise ValueError("ACP positive filtering requires a non-streaming dataset with a loaded hf_dataset.")
+    return hf_dataset
+
+
+def _allowed_absolute_indices_for_policy(dataset: Any, drop_n_last_frames: int) -> set[int] | None:
+    if drop_n_last_frames <= 0:
+        return None
+
+    episode_sampler = EpisodeAwareSampler(
+        dataset.meta.episodes["dataset_from_index"],
+        dataset.meta.episodes["dataset_to_index"],
+        episode_indices_to_use=dataset.episodes,
+        drop_n_last_frames=drop_n_last_frames,
+        shuffle=False,
+    )
+    return set(episode_sampler.indices)
+
+
+def _get_acp_positive_sample_indices(
+    dataset: Any,
+    indicator_field: str,
+    drop_n_last_frames: int = 0,
+) -> list[int]:
+    """Return dataset row indices whose ACP indicator is positive."""
+
+    hf_dataset = _load_hf_dataset_for_sampling(dataset)
+    column_names = getattr(hf_dataset, "column_names", None)
+    if column_names is not None and indicator_field not in column_names:
+        raise KeyError(f"ACP indicator field '{indicator_field}' is not present in the dataset.")
+
+    indicator_values = hf_dataset[indicator_field]
+    absolute_indices = hf_dataset["index"] if column_names is None or "index" in column_names else None
+    allowed_absolute_indices = _allowed_absolute_indices_for_policy(dataset, drop_n_last_frames)
+
+    positive_indices: list[int] = []
+    invalid_count = 0
+    for row_idx, value in enumerate(indicator_values):
+        values = torch.as_tensor(value).reshape(-1)
+        if values.numel() == 0:
+            invalid_count += 1
+            continue
+        invalid_count += int((~((values == 0) | (values == 1))).sum().item())
+        if not bool((values == 1).any().item()):
+            continue
+
+        if allowed_absolute_indices is not None and absolute_indices is not None:
+            abs_idx = int(torch.as_tensor(absolute_indices[row_idx]).reshape(-1)[0].item())
+            if abs_idx not in allowed_absolute_indices:
+                continue
+
+        positive_indices.append(row_idx)
+
+    if invalid_count > 0:
+        logging.warning(
+            "ACP positive filtering saw %d non-binary or empty indicator values in field '%s'.",
+            invalid_count,
+            indicator_field,
+        )
+    if not positive_indices:
+        raise ValueError(
+            f"ACP positive filtering found no positive samples for field '{indicator_field}'. "
+            "Run value inference first or lower the ACP threshold."
+        )
+    return positive_indices
+
+
+def _get_acp_sample_weights(
+    dataset: Any,
+    indicator_field: str,
+    positive_sample_weight: float,
+    drop_n_last_frames: int = 0,
+) -> tuple[torch.Tensor, int, int]:
+    """Return per-row sampling weights that upweight ACP-positive rows."""
+
+    hf_dataset = _load_hf_dataset_for_sampling(dataset)
+    column_names = getattr(hf_dataset, "column_names", None)
+    if column_names is not None and indicator_field not in column_names:
+        raise KeyError(f"ACP indicator field '{indicator_field}' is not present in the dataset.")
+
+    indicator_values = hf_dataset[indicator_field]
+    absolute_indices = hf_dataset["index"] if column_names is None or "index" in column_names else None
+    allowed_absolute_indices = _allowed_absolute_indices_for_policy(dataset, drop_n_last_frames)
+
+    weights = torch.ones(len(indicator_values), dtype=torch.double)
+    positive_count = 0
+    eligible_count = 0
+    invalid_count = 0
+    for row_idx, value in enumerate(indicator_values):
+        if allowed_absolute_indices is not None and absolute_indices is not None:
+            abs_idx = int(torch.as_tensor(absolute_indices[row_idx]).reshape(-1)[0].item())
+            if abs_idx not in allowed_absolute_indices:
+                weights[row_idx] = 0.0
+                continue
+
+        eligible_count += 1
+        values = torch.as_tensor(value).reshape(-1)
+        if values.numel() == 0:
+            invalid_count += 1
+            continue
+        invalid_count += int((~((values == 0) | (values == 1))).sum().item())
+        if bool((values == 1).any().item()):
+            weights[row_idx] = positive_sample_weight
+            positive_count += 1
+
+    if invalid_count > 0:
+        logging.warning(
+            "ACP weighted sampling saw %d non-binary or empty indicator values in field '%s'.",
+            invalid_count,
+            indicator_field,
+        )
+    if eligible_count == 0 or float(weights.sum().item()) <= 0.0:
+        raise ValueError(
+            f"ACP weighted sampling found no eligible samples for field '{indicator_field}'."
+        )
+    return weights, positive_count, eligible_count
+
