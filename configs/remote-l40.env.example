# Copy this file to configs/remote-l40.env and edit it locally.
# The copied file is ignored by git.

# SSH alias from ~/.ssh/config. Your local config currently has hpc-server and hpc-hopper.
REMOTE_HOST=hpc-hopper

# Use a temporary filesystem on the L40 server. The runner removes this after pulling results back.
REMOTE_BASE=/tmp/$USER/recap-sim-l40

# Existing Python environment on the remote server.
# Keep this as shell code because HPC clusters often need module/conda setup.
REMOTE_ENV_SETUP=source ~/miniconda3/etc/profile.d/conda.sh && conda activate evo-rl

# Optional commands before the job starts, for example:
# REMOTE_BEFORE=module load cuda/12.1
REMOTE_BEFORE=

# Optional Hugging Face token setup if the remote environment does not already have one.
# Do not commit real tokens.
HF_TOKEN=
